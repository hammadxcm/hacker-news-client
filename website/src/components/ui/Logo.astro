---
interface Props {
  size?: number;
}
const { size = 28 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect width="32" height="32" rx="7" fill="var(--color-brand)"></rect>
  <path
    d="M10 8L16 16L10 24M16 24L22 24"
    stroke="#0b0d12"
    stroke-width="2.4"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>
