---
import { languages } from '../../data/languages';

const repeated = [...languages, ...languages, ...languages];
---

<section class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {
      repeated.map((lang, i) => (
        <span class="marquee-item" data-idx={i}>
          <span class="marquee-dot" style={`background: ${lang.iconColor}`} />
          <span class="marquee-name">{lang.name}</span>
          <span class="marquee-pkg">{lang.packageName}</span>
        </span>
      ))
    }
  </div>
</section>

<style>
  .marquee {
    border-block: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    overflow: hidden;
    padding-block: 16px;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .marquee-track {
    display: inline-flex;
    gap: 48px;
    white-space: nowrap;
    animation: marquee-scroll 56s linear infinite;
    will-change: transform;
  }

  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text-secondary);
    font-size: 14px;
  }

  .marquee-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    box-shadow: 0 0 0 3px var(--color-bg-base);
  }

  .marquee-name {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .marquee-pkg {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
