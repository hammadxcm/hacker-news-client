---
import { defaultLocale, type LocaleId } from '../../data/locales';
import { site } from '../../data/site';
import { getTranslator } from '../../i18n';

interface Props {
  locale?: LocaleId;
}

const { locale = defaultLocale } = Astro.props;
const t = getTranslator(locale);
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-name">{site.name}</p>
      <p class="footer-tagline">{t('footer.tagline')}</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={site.repo} rel="noopener" target="_blank">{t('footer.repo')}</a>
      <a href={site.designContractUrl} rel="noopener" target="_blank">{t('footer.design')}</a>
      <a href={site.hnApiUrl} rel="noopener" target="_blank">{t('footer.api')}</a>
    </nav>
  </div>

  <div class="container">
    <p class="footer-copy">{t('footer.copyright')}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: 64px 32px;
    margin-top: 80px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: start;
  }

  .footer-name {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 8px;
  }

  .footer-tagline {
    color: var(--color-text-secondary);
    max-width: 360px;
    font-size: 14px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .footer-links a:hover {
    color: var(--color-brand);
  }

  .footer-copy {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    font-size: 13px;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
